{
  "project": "monopoly",
  "stack": {
    "host": "cloudflare-workers",
    "framework": "tanstack-start",
    "backend": "convex",
    "auth": "none",
    "packageManager": "pnpm",
    "publicPrefix": "VITE_"
  },
  "vaults": {
    "app": "monopoly-app",
    "ci": "monopoly-ci"
  },
  "source": {
    "kind": "1password",
    "envFiles": [
      ".env.1password"
    ]
  },
  "ignorePrefixes": [],
  "environments": [
    {
      "name": "dev",
      "sourceConfig": ".env.1password",
      "branch": null,
      "wranglerEnv": null,
      "wranglerConfigs": null,
      "convexDeployTarget": "dev",
      "vercelEnvironment": null,
      "githubEnvironment": null,
      "easProfile": null
    },
    {
      "name": "production",
      "sourceConfig": ".env.production.1password",
      "branch": "main",
      "wranglerEnv": null,
      "wranglerConfigs": [
        "wrangler.jsonc"
      ],
      "convexDeployTarget": "prod",
      "vercelEnvironment": null,
      "githubEnvironment": "production",
      "easProfile": null
    }
  ],
  "keys": {
    "CLOUDFLARE_API_TOKEN": {
      "class": "secret",
      "vault": "ci",
      "destinations": [
        "github-env"
      ]
    },
    "CONVEX_DEPLOYMENT": {
      "class": "ignore",
      "destinations": []
    },
    "CONVEX_DEPLOY_KEY": {
      "class": "secret",
      "vault": "ci",
      "destinations": [
        "github-env"
      ]
    },
    "OPENROUTER_API_KEY": {
      "class": "secret",
      "vault": "app",
      "destinations": [
        "convex"
      ]
    },
    "VITE_ADMIN_PASSPHRASE": {
      "class": "public",
      "destinations": [
        "bundle"
      ]
    },
    "VITE_CONVEX_URL": {
      "class": "public",
      "destinations": [
        "bundle"
      ]
    }
  }
}
